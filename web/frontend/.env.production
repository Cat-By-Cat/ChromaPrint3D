# API server base URL for production cross-origin deployment.
# Leave empty for single-origin mode (frontend and API on same host).
# Example: VITE_API_BASE=https://api.example.com:9443
VITE_API_BASE=https://api.example.com:9443

# Optional: browser footer ICP filing information.
# Keep the real filing number in .env.production.local to avoid committing it.
# VITE_SITE_ICP_NUMBER=京ICP备12345678号-1
# VITE_SITE_ICP_URL=https://beian.miit.gov.cn/

# Optional: browser footer public security filing information.
# VITE_SITE_PUBLIC_SECURITY_RECORD_NUMBER=京公网安备11010502000001号
# VITE_SITE_PUBLIC_SECURITY_RECORD_URL=https://beian.mps.gov.cn/
