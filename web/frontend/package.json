{
  "name": "chromaprint3d-web",
  "version": "1.3.2-rc.1",
  "description": "Web frontend for ChromaPrint3D — multi-color 3D print image processor",
  "type": "module",
  "license": "Apache-2.0",
  "author": "neroued <neroued@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/neroued/ChromaPrint3D.git",
    "directory": "web"
  },
  "keywords": [
    "3d-printing",
    "multi-color",
    "3mf",
    "color-matching",
    "vue"
  ],
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc -b --pretty false",
    "lint:eslint": "eslint . --max-warnings 0",
    "lint": "npm run typecheck && npm run lint:eslint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "naive-ui": "^2.43.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.25",
    "vue-i18n": "^11.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.1",
    "@vicons/ionicons5": "^0.13.0",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.1.5"
  }
}
