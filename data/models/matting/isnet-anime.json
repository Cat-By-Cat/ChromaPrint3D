{
    "name": "IS-Net Anime",
    "description": "高分辨率模型，针对动漫和插画风格图像优化，精度高但速度较慢",
    "preprocess": {
        "input_size": 1024,
        "channel_order": "rgb",
        "layout": "nchw",
        "normalize_scale": 0.00392156862,
        "normalize_mean": [0.485, 0.456, 0.406],
        "normalize_std": [0.229, 0.224, 0.225]
    },
    "postprocess": {
        "output_index": 0,
        "threshold": 0.5
    }
}
